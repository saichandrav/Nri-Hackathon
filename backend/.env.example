# Server
PORT=8000
MONGO_URI=mongodb://localhost:27017/jobapplicationai

# JWT
JWT_SECRET=replace_me_with_a_random_secret

# SMTP (for nodemailer OTP emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password
OTP_FROM_EMAIL=your_email@example.com

# Debug: if true, OTP will be printed to the server console (development only)
OTP_DEBUG=false

# Python AI Engine URL
PYTHON_API_URL=http://localhost:8001

# OpenAI (optional, used for resume text extraction)
OPENAI_API_KEY=your_openai_api_key_here
